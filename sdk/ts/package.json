{
  "name": "janus-client",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the Janus secrets manager: programmatic secret reads with an in-process TTL cache and dynamic-credential leases.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "janus",
    "secrets",
    "secrets-manager",
    "sdk",
    "client"
  ],
  "dependencies": {},
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
